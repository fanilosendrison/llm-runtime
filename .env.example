# ─────────────────────────────────────────────────────────────
# @vegacorp/llm-runtime — Environment Variables
# Copy this file to .env and fill in your API keys.
# ─────────────────────────────────────────────────────────────

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT, embeddings)
OPENAI_API_KEY=sk-...

# Google (Gemini)
GOOGLE_API_KEY=AIza...

# OpenAI-compatible providers (optional — pick what you need)
DEEPSEEK_API_KEY=sk-...
MISTRAL_API_KEY=...
GROQ_API_KEY=gsk_...
TOGETHER_API_KEY=...

# Ollama (local, no key needed by default)
# OLLAMA_ENDPOINT=http://localhost:11434
